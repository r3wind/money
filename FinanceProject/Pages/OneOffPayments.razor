@page "/one-off-payments"
@inject FinanceStateService Finance

<PageTitle>One-Off Payments</PageTitle>

<h1 class="page-title">💸 One-Off Incoming Payments</h1>

<div class="stat-sub mb-3">These one-off payments are money coming into your balance and are included in dashboard and forecast calculations.</div>

<button class="btn btn-primary mb-3" @onclick="OpenAddForm">+ Add One-Off Payment</button>

@if (_showForm)
{
    <div class="form-card">
        <h2 class="form-card__title">@(_editingId == null ? "Add One-Off Payment" : "Edit One-Off Payment")</h2>
        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="_form.Name" placeholder="e.g. Tax refund" />
                <ValidationMessage For="() => _form.Name" />
            </div>
            <div class="mb-3">
                <label class="form-label">Amount (£)</label>
                <InputNumber class="form-control" @bind-Value="_form.Amount" />
                <ValidationMessage For="() => _form.Amount" />
            </div>
            <div class="mb-3">
                <label class="form-label">Date</label>
                <InputDate class="form-control" @bind-Value="_form.Date" />
                <ValidationMessage For="() => _form.Date" />
            </div>
            <div class="mb-3">
                <label class="form-label">Details (optional)</label>
                <InputTextArea class="form-control" @bind-Value="_form.Details" rows="2" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                    Save
                </button>
                <button type="button" class="btn btn-secondary" @onclick="CancelForm" disabled="@_saving">Cancel</button>
            </div>
        </EditForm>
    </div>
}

@if (!_loaded)
{
    <div class="d-flex align-items-center gap-2 text-muted my-3">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        Loading...
    </div>
}
else if (Finance.OneOffPayments.Count == 0)
{
    <div class="empty-state">No one-off payments added yet.</div>
}
else
{
    <div class="item-list">
        @foreach (var payment in Finance.OneOffPayments.OrderBy(u => u.Date))
        {
            <div class="item-card @(payment.Date < DateTime.Today ? "item-card--past" : "")">
                <div class="item-card__header">
                    <span class="item-card__name">@payment.Name</span>
                    <span class="item-card__amount">@payment.Amount.ToGBP()</span>
                </div>
                <div class="item-card__meta">@payment.Date.ToString("dd MMM yyyy")</div>
                @if (!string.IsNullOrWhiteSpace(payment.Details))
                {
                    <div class="item-card__details">@payment.Details</div>
                }
                <div class="item-card__actions">
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditForm(payment)">Edit</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmRemove(payment.Id)">Remove</button>
                </div>
            </div>
        }
    </div>
}

@if (_confirmRemoveId != null)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-simple">
            <p>Are you sure you want to remove this one-off payment?</p>
            <div class="form-actions">
                <button class="btn btn-danger" @onclick="RemoveConfirmedAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                    Remove
                </button>
                <button class="btn btn-secondary" @onclick="() => _confirmRemoveId = null" disabled="@_saving">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool _saving;
    private bool _showForm;
    private Guid? _editingId;
    private Guid? _confirmRemoveId;

    private OneOffPayment _form = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Finance.LoadAsync();
            _loaded = true;
            StateHasChanged();
        }
    }

    private void OpenAddForm()
    {
        _form = new OneOffPayment();
        _editingId = null;
        _showForm = true;
    }

    private void OpenEditForm(OneOffPayment payment)
    {
        _form = new OneOffPayment
        {
            Id = payment.Id,
            Name = payment.Name,
            Amount = payment.Amount,
            Date = payment.Date,
            Details = payment.Details
        };
        _editingId = payment.Id;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _editingId = null;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        if (_editingId == null)
            await Finance.AddOneOffPaymentAsync(_form);
        else
            await Finance.UpdateOneOffPaymentAsync(_form);
        _saving = false;
        _showForm = false;
        _editingId = null;
    }

    private void ConfirmRemove(Guid id) => _confirmRemoveId = id;

    private async Task RemoveConfirmedAsync()
    {
        _saving = true;
        if (_confirmRemoveId != null)
            await Finance.RemoveOneOffPaymentAsync(_confirmRemoveId.Value);
        _saving = false;
        _confirmRemoveId = null;
    }
}
