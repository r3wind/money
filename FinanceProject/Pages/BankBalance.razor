@page "/bank-balance"
@inject FinanceStateService Finance

<PageTitle>Bank Balance</PageTitle>

<h1 class="page-title">🏦 Bank Balance</h1>

@if (!_loaded)
{
    <div class="d-flex align-items-center gap-2 text-muted my-3">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        Loading...
    </div>
}
else
{
    <div class="form-card">
        <h2 class="form-card__title">Current Account Balance</h2>
        <p class="text-muted" style="font-size:0.88rem;">Enter your current bank balance. The dashboard will use this to calculate your projected balance after all remaining direct debits and pro-rated budget are accounted for.</p>
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label">Balance (£)</label>
                <InputNumber class="form-control form-control-lg" @bind-Value="_model.Amount" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                    Save Balance
                </button>
            </div>
        </EditForm>
    </div>

    @if (Finance.BankBalance != 0)
    {
        <div class="balance-summary">
            <div class="balance-row">
                <span>Current balance</span>
                <span class="balance-value">@Finance.BankBalance.ToGBP()</span>
            </div>
            <div class="balance-row balance-row--deduct">
                <span>Remaining direct debits</span>
                <span class="balance-value">− @Finance.RemainingMonthDirectDebits().ToGBP()</span>
            </div>
            <div class="balance-row balance-row--deduct">
                <span>Pro-rated budget (@_budgetFractionPercent% of monthly)</span>
                <span class="balance-value">− @Finance.ProRatedBudget().ToGBP()</span>
            </div>
            <div class="balance-row balance-row--total @(Finance.ProjectedBalance() < 0 ? "balance-row--negative" : "balance-row--positive")">
                <span>Projected remaining balance</span>
                <span class="balance-value">@Finance.ProjectedBalance().ToGBP()</span>
            </div>
        </div>
    }
}

@if (_saved)
{
    <div class="alert alert-success mt-3" role="alert">Balance saved.</div>
}

@code {
    private bool _loaded;
    private bool _saving;
    private bool _saved;
    private string _budgetFractionPercent = "0";

    private BalanceModel _model = new();

    private class BalanceModel
    {
        public decimal Amount { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Finance.LoadAsync();
            _model.Amount = Finance.BankBalance;

            var today = DateTime.Today;
            var daysInMonth = DateTime.DaysInMonth(today.Year, today.Month);
            var remainingDays = daysInMonth - today.Day + 1;
            _budgetFractionPercent = Math.Round((decimal)remainingDays / daysInMonth * 100, 0).ToString();

            _loaded = true;
            StateHasChanged();
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        await Finance.SetBankBalanceAsync(_model.Amount);
        _saving = false;
        _saved = true;
        StateHasChanged();
        await Task.Delay(2000);
        _saved = false;
        StateHasChanged();
    }
}
