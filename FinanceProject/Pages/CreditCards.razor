@page "/credit-cards"
@inject FinanceStateService Finance

<PageTitle>Credit Cards</PageTitle>

<h1 class="page-title">💳 Credit Cards</h1>

<button class="btn btn-primary mb-3" @onclick="OpenAddForm">+ Add Credit Card</button>

@if (_showForm)
{
    <div class="form-card">
        <h2 class="form-card__title">@(_editingId == null ? "Add Credit Card" : "Edit Credit Card")</h2>
        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label">Card Name</label>
                <InputText class="form-control" @bind-Value="_form.Name" placeholder="e.g. Barclaycard" />
                <ValidationMessage For="() => _form.Name" />
            </div>
            <div class="mb-3">
                <label class="form-label">Credit Limit (£)</label>
                <InputNumber class="form-control" @bind-Value="_form.Limit" />
                <ValidationMessage For="() => _form.Limit" />
            </div>
            <div class="mb-3">
                <label class="form-label">Available Credit (£)</label>
                <InputNumber class="form-control" @bind-Value="_form.AvailableCredit" />
                <ValidationMessage For="() => _form.AvailableCredit" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                    Save
                </button>
                <button type="button" class="btn btn-secondary" @onclick="CancelForm" disabled="@_saving">Cancel</button>
            </div>
        </EditForm>
    </div>
}

@if (!_loaded)
{
    <div class="d-flex align-items-center gap-2 text-muted my-3">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        Loading...
    </div>
}
else if (Finance.CreditCards.Count == 0)
{
    <div class="empty-state">No credit cards added yet.</div>
}
else
{
    <div class="item-list">
        @foreach (var card in Finance.CreditCards)
        {
            <div class="item-card">
                <div class="item-card__header">
                    <span class="item-card__name">@card.Name</span>
                    <span class="item-card__amount">@card.Balance.ToGBP() to pay</span>
                </div>
                <div class="item-card__meta">
                    Limit @card.Limit.ToGBP() &nbsp;·&nbsp; Available @card.AvailableCredit.ToGBP()
                </div>
                <div class="item-card__actions">
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditForm(card)">Edit</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmRemove(card.Id)">Remove</button>
                </div>
            </div>
        }
    </div>
    <div class="total-bar">
        Total outstanding balance: <strong>@Finance.TotalCreditCardBalance().ToGBP()</strong>
        &nbsp;·&nbsp; this is deducted from your forecast balance
    </div>
}

@if (_confirmRemoveId != null)
{
    <div class="modal-backdrop">
        <div class="modal-dialog-simple">
            <p>Remove this credit card?</p>
            <div class="form-actions">
                <button class="btn btn-danger" @onclick="RemoveConfirmedAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                    Remove
                </button>
                <button class="btn btn-secondary" @onclick="() => _confirmRemoveId = null" disabled="@_saving">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool _saving;
    private bool _showForm;
    private Guid? _editingId;
    private Guid? _confirmRemoveId;

    private CreditCard _form = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Finance.LoadAsync();
            _loaded = true;
            StateHasChanged();
        }
    }

    private void OpenAddForm()
    {
        _form = new CreditCard();
        _editingId = null;
        _showForm = true;
    }

    private void OpenEditForm(CreditCard card)
    {
        _form = new CreditCard
        {
            Id = card.Id,
            Name = card.Name,
            Limit = card.Limit,
            AvailableCredit = card.AvailableCredit
        };
        _editingId = card.Id;
        _showForm = true;
    }

    private void CancelForm() => _showForm = false;

    private async Task SaveAsync()
    {
        _saving = true;
        if (_editingId == null)
            await Finance.AddCreditCardAsync(_form);
        else
            await Finance.UpdateCreditCardAsync(_form);
        _saving = false;
        _showForm = false;
        StateHasChanged();
    }

    private void ConfirmRemove(Guid id) => _confirmRemoveId = id;

    private async Task RemoveConfirmedAsync()
    {
        _saving = true;
        if (_confirmRemoveId != null)
        {
            await Finance.RemoveCreditCardAsync(_confirmRemoveId.Value);
            _confirmRemoveId = null;
        }
        _saving = false;
        StateHasChanged();
    }
}
