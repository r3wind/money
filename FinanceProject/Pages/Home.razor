@page "/"
@inject FinanceStateService Finance
@implements IAsyncDisposable

<PageTitle>Dashboard</PageTitle>

<h1 class="page-title">📊 Dashboard</h1>

@if (!_loaded)
{
    <div class="d-flex align-items-center gap-2 text-muted my-3">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        Loading...
    </div>
}
else
{
    <div class="dashboard-grid">
        @if (Finance.BankBalance != 0)
        {
            var endOfMonthBalance = Finance.ProjectedBalance();
            var projectedWithSavings = endOfMonthBalance + Finance.UnallocatedSavings();
            var nextMonthForecastVal = Finance.NextMonthForecastAfterBills();
            var nextMonthName = DateTime.Today.AddMonths(1).ToString("MMMM");
            var riskBalance = Finance.BankBalance
                - Finance.RemainingMonthDirectDebits()
                - Finance.ProRatedBudget()
                - Finance.UpcomingCosts.Where(u => u.Date >= DateTime.Today).Sum(u => u.Amount)
                - Finance.TotalCreditCardBalance();

            <div class="stat-card stat-card--featured @(nextMonthForecastVal < 0 ? "stat-card--danger" : "stat-card--highlight")">
                <div class="stat-label">Forecast after <b>@nextMonthName's bills</b></div>
                <div class="stat-value">@nextMonthForecastVal.ToGBP()</div>
                <button class="btn btn-sm btn-outline-light mt-1" @onclick="() => _showBreakdownNextMonth = !_showBreakdownNextMonth">@(_showBreakdownNextMonth ? "Hide breakdown" : "Show breakdown")</button>
                @if (_showBreakdownNextMonth)
                {
                    <div class="stat-sub" style="margin-top:0.6rem;">
                        Bank balance: @Finance.BankBalance.ToGBP()<br />
                        − Remaining debits this month: @Finance.RemainingMonthDirectDebits().ToGBP()<br />
                        − Pro-rated budget this month (@_budgetFractionPercent%): @Finance.ProRatedBudget().ToGBP()<br />
                        − Upcoming costs this month: @Finance.UpcomingCosts.Where(u => u.Date >= DateTime.Today).Sum(u => u.Amount).ToGBP()<br />
                        − @nextMonthName debits: @Finance.NextMonthDirectDebits().ToGBP()<br />
                        − Full monthly budget: @Finance.FullMonthlyBudget().ToGBP()<br />
                        − @nextMonthName upcoming costs: @Finance.NextMonthUpcomingCosts().ToGBP()<br />
                        − Credit cards: @Finance.TotalCreditCardBalance().ToGBP()<br />
                        + Unpaid income: @Finance.UnpaidIncome().ToGBP()<br />
                        + Unallocated savings: @Finance.UnallocatedSavings().ToGBP()
                    </div>
                }
            </div>

            <div class="stat-card @(endOfMonthBalance < 0 ? "stat-card--danger" : "stat-card--success")">
                <div class="stat-label">Bank balance end of this month</div>
                <div class="stat-value">@endOfMonthBalance.ToGBP()</div>
                <button class="btn btn-sm btn-outline-light mt-1" @onclick="() => _showBreakdownEndOfMonth = !_showBreakdownEndOfMonth">@(_showBreakdownEndOfMonth ? "Hide breakdown" : "Show breakdown")</button>
                @if (_showBreakdownEndOfMonth)
                {
                    <div class="stat-sub" style="margin-top:0.4rem;">
                        Bank balance: @Finance.BankBalance.ToGBP()<br />
                        − Remaining debits: @Finance.RemainingMonthDirectDebits().ToGBP()<br />
                        − Pro-rated budget (@_budgetFractionPercent%): @Finance.ProRatedBudget().ToGBP()<br />
                        − Upcoming costs: @Finance.UpcomingCosts.Where(u => u.Date >= DateTime.Today).Sum(u => u.Amount).ToGBP()<br />
                        + Unpaid income: @Finance.UnpaidIncome().ToGBP()<br />
                        − Credit cards: @Finance.TotalCreditCardBalance().ToGBP()
                    </div>
                }
            </div>

            <div class="stat-card @(projectedWithSavings < 0 ? "stat-card--danger" : "stat-card--highlight")">
                <div class="stat-label">Projected balance <b>incl. unallocated savings</b></div>
                <div class="stat-value">@projectedWithSavings.ToGBP()</div>
                <button class="btn btn-sm btn-outline-light mt-1" @onclick="() => _showBreakdownProjectedWithSavings = !_showBreakdownProjectedWithSavings">@(_showBreakdownProjectedWithSavings ? "Hide breakdown" : "Show breakdown")</button>
                @if (_showBreakdownProjectedWithSavings)
                {
                    <div class="stat-sub" style="margin-top:0.4rem;">
                        End of month balance: @endOfMonthBalance.ToGBP()<br />
                        + Unallocated savings: @Finance.UnallocatedSavings().ToGBP()
                    </div>
                }
            </div>

            <div class="stat-card stat-card--muted">
                <div class="stat-label">Allocated savings commitments</div>
                <div class="stat-value">@Finance.SavingsSubPots.Sum(p => p.Amount).ToGBP()</div>
                <button class="btn btn-sm btn-outline-secondary mt-1" @onclick="() => _showBreakdownNonUnallocated = !_showBreakdownNonUnallocated">@(_showBreakdownNonUnallocated ? "Hide breakdown" : "Show breakdown")</button>
                @if (_showBreakdownNonUnallocated)
                {
                    <div class="stat-sub" style="margin-top:0.4rem;">
                        Not included in the projected balance.<br />
                        @foreach (var pot in Finance.SavingsSubPots)
                        {
                            <span>@pot.Name: @pot.Amount.ToGBP()</span><br />
                        }
                    </div>
                }
            </div>

            <div class="stat-card @(riskBalance < 0 ? "stat-card--danger" : "stat-card--success")">
                <div class="stat-label">Risk of Negative Balance This Month</div>
                <div class="stat-value">@riskBalance.ToGBP()</div>
                <button class="btn btn-sm btn-outline-light mt-1" @onclick="() => _showBreakdownRisk = !_showBreakdownRisk">@(_showBreakdownRisk ? "Hide breakdown" : "Show breakdown")</button>
                @if (_showBreakdownRisk)
                {
                    <div class="stat-sub" style="margin-top:0.4rem;">
                        Bank balance: @Finance.BankBalance.ToGBP()<br />
                        − Remaining debits: @Finance.RemainingMonthDirectDebits().ToGBP()<br />
                        − Pro-rated budget (@_budgetFractionPercent%): @Finance.ProRatedBudget().ToGBP()<br />
                        − Upcoming costs: @Finance.UpcomingCosts.Where(u => u.Date >= DateTime.Today).Sum(u => u.Amount).ToGBP()<br />
                        − Credit cards: @Finance.TotalCreditCardBalance().ToGBP()<br />
                        Formula: Bank balance − debits − budget − upcoming costs − credit cards
                    </div>
                }
                @if (riskBalance < 0)
                {
                    <div class="stat-sub" style="color:#fff;font-weight:600;margin-top:0.5rem;">⚠️ Warning: Your account may go negative this month.</div>
                }
                else
                {
                    <div class="stat-sub" style="color:#fff;font-weight:600;margin-top:0.5rem;">✅ No risk of negative balance this month.</div>
                }
            </div>
        }
        else
        {
            <div class="stat-card stat-card--muted">
                <div class="stat-label">Forecast &amp; balance</div>
                <div class="stat-value">—</div>
                <div class="stat-sub"><a href="bank-balance">Enter your bank balance</a> to see forecasts</div>
            </div>
        }

        <div class="stat-card">
            <div class="stat-label">Total monthly direct debits</div>
            <div class="stat-value">@Finance.TotalMonthlyDirectDebits().ToGBP()</div>
            <button class="btn btn-sm btn-outline-secondary mt-1" @onclick="() => _showBreakdownDirectDebits = !_showBreakdownDirectDebits">@(_showBreakdownDirectDebits ? "Hide breakdown" : "Show breakdown")</button>
            @if (_showBreakdownDirectDebits)
            {
                <div class="stat-sub" style="margin-top:0.4rem;">
                    @foreach (var dd in Finance.DirectDebits)
                    {
                        <span>@dd.Name: @dd.Amount.ToGBP()</span><br />
                    }
                </div>
            }
        </div>

        <div class="stat-card">
            <div class="stat-label">Direct debits remaining this month</div>
            <div class="stat-value">@Finance.RemainingMonthDirectDebits().ToGBP()</div>
            <button class="btn btn-sm btn-outline-secondary mt-1" @onclick="() => _showBreakdownRemainingDebits = !_showBreakdownRemainingDebits">@(_showBreakdownRemainingDebits ? "Hide breakdown" : "Show breakdown")</button>
            @if (_showBreakdownRemainingDebits)
            {
                <div class="stat-sub" style="margin-top:0.4rem;">
                    From @DateTime.Today.ToString("dd MMM") to end of month:<br />
                    @foreach (var dd in Finance.DirectDebits.Where(d => d.DayOfMonth >= DateTime.Today.Day))
                    {
                        <span>@dd.Name: @dd.Amount.ToGBP()</span><br />
                    }
                </div>
            }
        </div>

        <div class="stat-card">
            <div class="stat-label">Remaining debits + pro-rated budget</div>
            <div class="stat-value">@Finance.RemainingMonthTotal().ToGBP()</div>
            <button class="btn btn-sm btn-outline-secondary mt-1" @onclick="() => _showBreakdownProRated = !_showBreakdownProRated">@(_showBreakdownProRated ? "Hide breakdown" : "Show breakdown")</button>
            @if (_showBreakdownProRated)
            {
                <div class="stat-sub" style="margin-top:0.4rem;">
                    Remaining debits: @Finance.RemainingMonthDirectDebits().ToGBP()<br />
                    + Pro-rated budget (@_budgetFractionPercent%): @Finance.ProRatedBudget().ToGBP()
                </div>
            }
        </div>
    </div>

    @if (Finance.DirectDebits.Count > 0)
    {
        <h2 class="section-title">Direct Debits</h2>
        <div class="summary-list">
            @foreach (var dd in Finance.DirectDebits.OrderBy(d => d.DayOfMonth))
            {
                <div class="summary-item @(dd.DayOfMonth >= DateTime.Today.Day ? "summary-item--remaining" : "summary-item--past")">
                    <span class="summary-item__name">@dd.Name</span>
                    <span class="summary-item__meta">Day @dd.DayOfMonth</span>
                    <span class="summary-item__amount">@dd.Amount.ToGBP()</span>
                </div>
            }
        </div>
    }

    @if (Finance.BudgetCategories.Count > 0)
    {
        <h2 class="section-title">Monthly Budget</h2>
        <div class="summary-list">
            @foreach (var cat in Finance.BudgetCategories)
            {
                <div class="summary-item">
                    <span class="summary-item__name">@cat.Name</span>
                    <span class="summary-item__amount">@cat.MonthlyAmount.ToGBP()</span>
                </div>
            }
        </div>
    }

    @if (Finance.UpcomingCosts.Count > 0)
    {
        <h2 class="section-title">Upcoming Costs</h2>
        <div class="summary-list">
            @foreach (var cost in Finance.UpcomingCosts.OrderBy(u => u.Date))
            {
                <div class="summary-item @(cost.Date >= DateTime.Today ? "summary-item--remaining" : "summary-item--past")">
                    <span class="summary-item__name">@cost.Name</span>
                    <span class="summary-item__meta">@cost.Date.ToString("dd MMM yyyy")</span>
                    <span class="summary-item__amount">@cost.Amount.ToGBP()</span>
                </div>
            }
        </div>
    }

    @if (Finance.DirectDebits.Count == 0 && Finance.BudgetCategories.Count == 0 && Finance.UpcomingCosts.Count == 0)
    {
        <div class="empty-state">
            <p>No data yet. Use the menu to add direct debits, budget categories and upcoming costs.</p>
        </div>
    }
}

@code {
    private bool _loaded;
    private string _budgetFractionPercent = "0";

    // Dashboard breakdown toggles
    private bool _showBreakdownDirectDebits;
    private bool _showBreakdownRemainingDebits;
    private bool _showBreakdownProRated;
    private bool _showBreakdownEndOfMonth;
    private bool _showBreakdownProjectedWithSavings;
    private bool _showBreakdownNonUnallocated;
    private bool _showBreakdownNextMonth;
    private bool _showBreakdownRisk;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Finance.LoadAsync();
            var today = DateTime.Today;
            var daysInMonth = DateTime.DaysInMonth(today.Year, today.Month);
            var remainingDays = daysInMonth - today.Day + 1;
            _budgetFractionPercent = Math.Round((decimal)remainingDays / daysInMonth * 100, 0).ToString();
            _loaded = true;
            StateHasChanged();
        }
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}

